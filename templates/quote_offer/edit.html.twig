{% extends 'admin/base.html.twig' %}

{% block title %}Modifier l'offre | {{ parent() }}{% endblock %}

{% block breadcrumb %}
    <li><a class="dropdown-item" href="{{ path('app_quote_dashboard') }}">Gestion des devis</a></li>
    <li><a class="dropdown-item" href="{{ path('app_quote_view', {'id': offer.quote.id}) }}">Détails du devis #{{ offer.quote.id }}</a></li>
    <li><span class="dropdown-item disabled" aria-current="page">Modifier l'offre #{{ offer.id }}</span></li>
{% endblock %}

{# Filtre personnalisé pour rendre les liens cliquables #}
{% if false %}
    {# Cette approche ne fonctionne pas dans Twig standard, à implémenter avec une extension Twig #}
{% endif %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4 flex-wrap">
        <div class="d-flex align-items-center gap-2 min-w-0">
            <a href="{{ path('app_quote_view', {'id': offer.quote.id}) }}" class="btn btn-outline-secondary btn-sm p-2 d-inline-flex align-items-center justify-content-center flex-shrink-0" aria-label="Retour au devis" title="Retour au devis">
                <i data-lucide="arrow-left" width="20" height="20" aria-hidden="true"></i>
            </a>
            <h1 class="mb-0">Modifier l'offre #{{ offer.id }}</h1>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
            {% if offer.status == 'draft' %}
                <form method="post" action="{{ path('app_quote_offer_send', {'id': offer.id}) }}" style="display: inline-block" class="me-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('send' ~ offer.id) }}">
                    <button type="submit" class="btn btn-success">
                        <i data-lucide="send" class="me-2"></i> Envoyer au client
                    </button>
                </form>
            {% endif %}
            {% if offer.pdfFilePath %}
                <form method="post" action="{{ path('app_quote_offer_send_pdf', {'id': offer.id}) }}" style="display: inline-block" class="me-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('send_pdf' ~ offer.id) }}">
                    <button type="submit" class="btn btn-success">
                        <i data-lucide="mail" class="me-2"></i> Envoyer le devis
                    </button>
                </form>
                <a href="{{ asset(offer.pdfFilePath) }}" class="btn btn-primary me-2" target="_blank">
                    <i data-lucide="file-text" class="me-2"></i> Voir le PDF
                </a>
            {% endif %}
            <a href="{{ path('app_quote_offer_generate_pdf', {'id': offer.id}) }}" class="btn btn-info" target="_blank">
                <i data-lucide="file-plus" class="me-2"></i> Générer le PDF
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5 class="mb-0">Informations générales</h5>
                </div>
                <div class="admin-card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="flex-shrink-0">
                            <i data-lucide="info" class="icon-lg text-primary"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="mb-0">Offre #{{ offer.id }}</h6>
                            <p class="text-muted mb-0">{{ offer.title }}</p>
                        </div>
                    </div>
                    <hr>
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <span class="badge {{ offer.status == 'draft' ? 'bg-secondary' : (offer.status == 'sent' ? 'bg-info' : (offer.status == 'accepted' ? 'bg-success' : (offer.status == 'pending' ? 'bg-warning' : 'bg-danger'))) }}">
                                {{ offer.status == 'draft' ? 'Brouillon' : (offer.status == 'sent' ? 'Envoyée' : (offer.status == 'accepted' ? 'Acceptée' : (offer.status == 'pending' ? 'En attente' : 'Refusée'))) }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5 class="mb-0">Informations client</h5>
                </div>
                <div class="admin-card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="flex-shrink-0">
                            <i data-lucide="user" class="icon-lg text-primary"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="mb-0">{{ offer.quote.fullName }}</h6>
                            {% if offer.quote.company %}
                                <p class="text-muted mb-0">{{ offer.quote.company }}</p>
                            {% endif %}
                        </div>
                    </div>
                    <hr>
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <a href="mailto:{{ offer.quote.email }}" class="btn btn-sm btn-light me-2" data-bs-toggle="tooltip" title="Email: {{ offer.quote.email }}">
                                <i data-lucide="mail" class="icon-sm"></i>
                            </a>
                            <a href="tel:{{ offer.quote.phone }}" class="btn btn-sm btn-light" data-bs-toggle="tooltip" title="Téléphone: {{ offer.quote.phone }}">
                                <i data-lucide="phone" class="icon-sm"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5 class="mb-0">Produits demandés</h5>
                </div>
                <div class="admin-card-body">
                    <ul class="list-group">
                        {% for item in offer.quote.items %}
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="badge bg-secondary me-2">#{{ loop.index }}</span>
                                        <strong>{{ item.productType }}</strong>
                                        {% if item.quantity %}
                                            <span class="badge bg-primary ms-2">{{ item.quantity }} pcs</span>
                                        {% endif %}
                                    </div>
                                    <div class="d-flex">
                                        {% if item.budget %}
                                            <span class="me-2" title="Budget: {{ item.budget }} €">
                                                <i data-lucide="wallet" class="icon-sm text-success"></i>
                                            </span>
                                        {% endif %}
                                        {% if item.description %}
                                            <a href="#" class="me-2 toggle-description" data-target="description-{{ loop.index }}">
                                                <i data-lucide="file-text" class="icon-sm text-primary"></i>
                                            </a>
                                        {% endif %}
                                        {% if item.photoFilename %}
                                            <a href="#" class="me-2" data-bs-toggle="modal" data-bs-target="#imageModal{{ loop.index }}">
                                                <i data-lucide="image" class="icon-sm text-primary"></i>
                                            </a>
                                        {% else %}
                                            <span class="me-2" title="Pas d'image disponible">
                                                <i data-lucide="image-off" class="icon-sm text-muted"></i>
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div id="description-{{ loop.index }}" class="mt-2 description-content" style="display: none;">
                                    <p class="text-muted small mb-0" style="word-break: break-word; overflow-wrap: break-word;">{{ item.description|nl2br }}</p>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5 class="mb-0">Détails de l'offre</h5>
                </div>
                <div class="admin-card-body">
                    {{ form_start(form) }}
                    <div class="row">
                        <div class="col-md-4">
                            {{ form_row(form.title) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.status) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.rmbMgaExchangeRate) }}
                        </div>
                    </div>
                    
                    {{ form_row(form.description) }}

                    <div class="mt-4 mb-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Propositions de produits</h5>
                        <button type="button" class="btn btn-success rounded-circle p-0" id="add-product-proposal" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;" aria-label="Ajouter une proposition">
                            <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
                        </button>
                    </div>
                    <div class="product-proposals-container" data-prototype="{{ form_widget(form.productProposals.vars.prototype)|e('html_attr') }}" data-index="{{ form.productProposals|length }}">
                        {% if form.productProposals|length > 0 %}
                            {% for productProposalForm in form.productProposals %}
                                {% set pdata = productProposalForm.vars.data %}
                                {% set qi = pdata ? pdata.quoteItem : null %}
                                <div class="product-proposal-item mb-4">
                                    <div class="product-proposal-heading d-flex justify-content-between align-items-start mb-2">
                                        <div class="d-flex align-items-start gap-2">
                                            <span class="product-proposal-dot" aria-hidden="true"></span>
                                            <div>
                                                <div class="product-proposal-title fw-semibold">Proposition #{{ loop.index }}</div>
                                                <div class="product-proposal-subtitle text-muted small">{{ qi ? qi.productType : '' }}</div>
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-outline-danger btn-sm product-proposal-remove remove-product-proposal">
                                            <i data-lucide="trash-2"></i>
                                            <span class="product-proposal-remove--label ms-1">Supprimer</span>
                                        </button>
                                    </div>
                                    <div class="product-proposal-card border rounded bg-white">
                                        {% include 'quote_offer/_product_proposal_fields.html.twig' %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="alert alert-info">
                                Aucune proposition de produit ajoutée. Cliquez sur le bouton + pour commencer.
                            </div>
                        {% endif %}
                    </div>

                    <div class="mt-4">
                        <div class="shipping-options-toolbar d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h5 class="mb-0">Options d'expédition</h5>
                                <p class="small text-muted mb-0 mt-1">Chaque ligne correspond à un mode parmi les trois proposés (un par type, maximum trois).</p>
                            </div>
                            <button type="button" class="btn btn-outline-primary rounded-circle btn-add-shipping p-0" id="add-shipping-option" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;" aria-label="Ajouter une option d'expédition">
                                <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
                            </button>
                        </div>
                        {% include 'quote_offer/_shipping_client_banner.html.twig' %}
                        <div class="shipping-options-container" data-prototype="{{ include('quote_offer/_shipping_option_prototype.html.twig', { shippingOptionForm: form.shippingOptions.vars.prototype })|e('html_attr') }}" data-index="{{ form.shippingOptions|length }}">
                            {% if form.shippingOptions|length > 0 %}
                                {% for shippingOptionForm in form.shippingOptions %}
                                    <div class="shipping-option-item">
                                        {% include 'quote_offer/_shipping_option_card.html.twig' %}
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="alert alert-info">
                                    Aucune option d'expédition ajoutée. Cliquez sur le bouton + pour commencer.
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i data-lucide="save" class="me-2"></i> Enregistrer les modifications
                        </button>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{% for item in offer.quote.items %}
    {% if item.photoFilename %}
        <div class="modal fade" id="imageModal{{ loop.index }}" tabindex="-1" aria-labelledby="imageModalLabel{{ loop.index }}" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="imageModalLabel{{ loop.index }}">{{ item.productType }}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body text-center">
                        <img src="{{ asset('uploads/quote_photos/' ~ item.photoFilename) }}" class="img-fluid" alt="{{ item.productType }}">
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endfor %}

{% for proposal in offer.productProposals %}
    {% if proposal.images|length > 0 %}
        {% for image in proposal.images %}
            <div class="modal fade" id="proposalImageModal{{ proposal.id }}_{{ loop.index }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Image de proposition</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                        </div>
                        <div class="modal-body text-center">
                            <img src="{{ asset('uploads/product_proposals/' ~ image) }}" class="img-fluid" alt="Image de proposition">
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
{% endfor %}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('css/admin/product-proposal.css') }}">
<link rel="stylesheet" href="{{ asset('css/admin/shipping-option.css') }}">
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="{{ asset('js/exchange-rate.js') }}"></script>
<script src="{{ asset('js/product-proposal-form.js') }}"></script>
<script src="{{ asset('js/shipping-option-currency.js') }}"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialisation des tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
        
        // Fonction pour récupérer le taux de change RMB/MGA en temps réel
        function fetchExchangeRate() {
            const rmbRateField = document.querySelector('input[id$="rmbMgaExchangeRate"]');
            if (rmbRateField && !rmbRateField.value) {
                // Afficher un indicateur de chargement
                rmbRateField.setAttribute('placeholder', 'Chargement du taux...');
                rmbRateField.disabled = true;
                
                // Faire une requête à notre API
                fetch('{{ path('app_exchange_rate_api') }}')
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.rate) {
                            rmbRateField.value = data.rate;
                            // Ajouter un petit texte pour indiquer quand le taux a été récupéré et les infos de mise à jour
                            const helpText = rmbRateField.closest('.form-group').querySelector('.form-text');
                            if (helpText) {
                                let infoHtml = '<br><small class="text-success">Taux récupéré le ' + data.timestamp + '</small>';
                                if (data.last_update) {
                                    infoHtml += '<br><small class="text-muted">Dernière mise à jour: ' + data.last_update + '</small>';
                                }
                                if (data.next_update) {
                                    infoHtml += '<br><small class="text-muted">Prochaine mise à jour: ' + data.next_update + '</small>';
                                }
                                helpText.innerHTML += infoHtml;
                            }
                        } else {
                            rmbRateField.setAttribute('placeholder', 'Erreur lors de la récupération du taux');
                        }
                    })
                    .catch(error => {
                        console.error('Erreur lors de la récupération du taux de change:', error);
                        rmbRateField.setAttribute('placeholder', 'Erreur lors de la récupération du taux');
                    })
                    .finally(() => {
                        rmbRateField.disabled = false;
                    });
            }
        }
        
        // Si le champ est vide, récupérer le taux actuel
        const rmbRateField = document.querySelector('input[id$="rmbMgaExchangeRate"]');
        if (rmbRateField && !rmbRateField.value) {
            fetchExchangeRate();
        }

        // Remplacer toutes les options des selects quoteItem par une version avec numéro de badge
        function addNumbersToSelect(select) {
            // Création d'un tableau associatif des noms de produits et leurs numéros
            const productsMap = {};
            $('.list-group-item').each(function(i) {
                const badge = $(this).find('.badge.bg-secondary');
                const badgeNumber = badge.length ? badge.text() : '#' + (i + 1);
                const productName = $(this).find('strong').text().trim();
                productsMap[productName] = badgeNumber;
            });
            
            // Remplacer toutes les options sauf la première
            $(select).find('option').each(function(index) {
                if (index > 0 && $(this).text()) { // Ignorer l'option "Sélectionnez un produit"
                    const productName = $(this).text().trim();
                    if (productsMap[productName]) {
                        $(this).text(productsMap[productName] + ' - ' + productName);
                    }
                }
            });
        }
        
        // Appliquer aux selects existants
        $('select[id$="_quoteItem"]').each(function() {
            addNumbersToSelect(this);
        });
        
        // Surveiller les nouveaux selects ajoutés au DOM
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.addedNodes.length) {
                    mutation.addedNodes.forEach(function(node) {
                        if (node.nodeType === 1) { // ELEMENT_NODE
                            $(node).find('select[id$="_quoteItem"]').each(function() {
                                addNumbersToSelect(this);
                            });
                        }
                    });
                }
            });
        });
        
        observer.observe(document.body, { childList: true, subtree: true });
        
        // Rendre les liens cliquables dans les descriptions
        document.querySelectorAll('.description-content p').forEach(function(paragraph) {
            const content = paragraph.innerHTML;
            const linkedContent = content.replace(
                /(https?:\/\/[^\s<]+)/g, 
                '<a href="$1" target="_blank" class="text-primary">$1</a>'
            );
            paragraph.innerHTML = linkedContent;
        });
        
        // Code pour les propositions de produits
        let $productProposalsContainer = $('.product-proposals-container');
        let productProposalIndex = parseInt($productProposalsContainer.data('index'), 10) || 0;
        
        // Événements pour afficher/masquer les descriptions
        $('.toggle-description').on('click', function(e) {
            e.preventDefault();
            const targetId = $(this).data('target');
            $('#' + targetId).toggle();
        });
        
        // Génération automatique des propositions au chargement de la page
        // Vérifier s'il n'y a pas déjà des propositions
        if ($('.product-proposal-item', $productProposalsContainer).length === 0 || 
            ($productProposalsContainer.children().length === 1 && $productProposalsContainer.find('.alert').length > 0)) {
            
            // Récupérer tous les produits demandés
            const $quoteItems = $('.list-group-item');
            
            // Générer une proposition pour chaque produit
            if ($quoteItems.length > 0) {
                // Vider les alertes si présentes
                if ($productProposalsContainer.find('.alert').length > 0) {
                    $productProposalsContainer.empty();
                }
                
                $quoteItems.each(function(index) {
                    const productName = $(this).find('strong').text();
                    const productId = index; // Utiliser l'index comme ID temporaire
                    
                    // Créer une nouvelle proposition
                    addProductProposal(productId, productName);
                });
            }
        }
        
        function addProductProposal(productId = null, productName = null) {
            var prototype = $productProposalsContainer.data('prototype');
            var newForm = prototype.replace(/__name__/g, productProposalIndex);
            var wrap = document.createElement('div');
            wrap.innerHTML = newForm.trim();
            var $parsed = $(wrap);

            var $fileInput = $parsed.find('[id$="_imageFiles"]');
            var $imgGroup = $fileInput.closest('.product-proposal-field-images');
            if (!$imgGroup.length) {
                $imgGroup = $fileInput.closest('.mb-3');
            }
            var labelText = ($imgGroup.find('label').first().text() || '').trim() || 'Images du produit';
            $imgGroup.empty();
            $imgGroup.addClass('product-proposal-section');
            $imgGroup.append($('<span class="form-label d-block"></span>').text(labelText));
            var $dz = $('<div class="product-proposal-dropzone"></div>');
            var $dzArea = $('<label class="product-proposal-dropzone-area mb-0"></label>').attr('for', $fileInput.attr('id'));
            $dzArea.append('<i data-lucide="image" class="product-proposal-dropzone-icon"></i>');
            $dzArea.append('<span class="product-proposal-dropzone-text">Glissez vos images ici ou <span class="text-primary">parcourir</span></span>');
            $dzArea.append('<span class="product-proposal-dropzone-hint">PNG, JPG, WEBP — max 5 Mo par image</span>');
            $dzArea.append($fileInput);
            $dz.append($dzArea);
            $dz.append('<div class="image-upload-container"></div>');
            $imgGroup.append($dz);

            var $quoteItem = $parsed.find('[id$="_quoteItem"]').closest('.product-proposal-field-quote-item, .mb-3');
            $quoteItem.addClass('product-proposal-section');

            var $minPrice = $parsed.find('[id$="_minPrice"]').closest('.d-none, .mb-3');
            $minPrice.addClass('d-none');

            var $maxPrice = $parsed.find('[id$="_maxPrice"]').closest('.product-proposal-field-price, .mb-3');
            var $dimensions = $parsed.find('[id$="_dimensions"]').closest('.product-proposal-field-dimensions, .mb-3');
            var $weight = $parsed.find('[id$="_weight"]').closest('.product-proposal-field-weight, .mb-3');
            var $detailsRow = $('<div class="product-proposal-section py-3"><div class="row g-3 product-proposal-details-row"></div></div>');
            $detailsRow.find('.row').append($maxPrice, $dimensions, $weight);

            var $comments = $parsed.find('[id$="_comments"]').closest('.product-proposal-field-comments, .mb-3');
            $comments.addClass('product-proposal-section');

            var $removedBlock = $parsed.find('[id*="removedImages"]').first().closest('.d-none, .mb-3');
            if (!$removedBlock.length) {
                $removedBlock = $parsed.find('input[name*="removedImages"]').first().closest('.mb-3');
            }
            var $removedWrapper = $('<div class="d-none"></div>');
            if ($removedBlock.length) {
                $removedWrapper.append($removedBlock);
            }

            var $card = $('<div class="product-proposal-card border rounded bg-white"></div>');
            $card.append($imgGroup);
            $card.append('<hr class="product-proposal-divider my-0" />');
            $card.append($quoteItem);
            $card.append('<hr class="product-proposal-divider my-0" />');
            $card.append($minPrice);
            $card.append('<hr class="product-proposal-divider my-0" />');
            $card.append($detailsRow);
            $card.append('<hr class="product-proposal-divider my-0" />');
            $card.append($comments);
            $card.append($removedWrapper);

            var titleNum = productProposalIndex + 1;
            var $item = $('<div class="product-proposal-item mb-4"></div>');
            var $heading = $('<div class="product-proposal-heading d-flex justify-content-between align-items-start mb-2"></div>');
            var $left = $('<div class="d-flex align-items-start gap-2"></div>');
            $left.append('<span class="product-proposal-dot" aria-hidden="true"></span>');
            var $titles = $('<div></div>');
            $titles.append('<div class="product-proposal-title fw-semibold">Proposition #' + titleNum + '</div>');
            $titles.append('<div class="product-proposal-subtitle text-muted small"></div>');
            $left.append($titles);
            $heading.append($left);
            $heading.append(
                $('<button type="button" class="btn btn-outline-danger btn-sm product-proposal-remove remove-product-proposal"></button>')
                    .append('<i data-lucide="trash-2"></i>')
                    .append('<span class="product-proposal-remove--label ms-1">Supprimer</span>')
            );
            $item.append($heading);
            $item.append($card);

            $('.alert', $productProposalsContainer).remove();
            $productProposalsContainer.append($item);

            if (productId !== null) {
                var $select = $item.find('select[id$="_quoteItem"]');
                $select.find('option').each(function () {
                    if (this.textContent.indexOf('#' + (productId + 1) + ' - ' + productName) !== -1 && this.value) {
                        $select.val(this.value);
                        return false;
                    }
                });
            }

            productProposalIndex++;
            $productProposalsContainer.data('index', productProposalIndex);
            initProductProposalBlocks($item[0]);
        }
        
        $('#add-product-proposal').click(function() {
            addProductProposal();
        });
        
        $(document).on('click', '.remove-product-proposal', function() {
            $(this).closest('.product-proposal-item').remove();

            if ($('.product-proposal-item', $productProposalsContainer).length === 0) {
                $productProposalsContainer.append('<div class="alert alert-info">Aucune proposition de produit ajoutée. Cliquez sur le bouton + pour commencer.</div>');
            }
        });

        initProductProposalBlocks(document);
        
        // Options d'expédition
        let $shippingOptionsContainer = $('.shipping-options-container');
        let shippingOptionIndex = parseInt($shippingOptionsContainer.data('index'), 10) || 0;

        $('#add-shipping-option').click(function() {
            if ($('.shipping-option-item', $shippingOptionsContainer).length >= 3) {
                return;
            }
            let prototype = $shippingOptionsContainer.data('prototype');
            let newForm = prototype.replace(/__name__/g, shippingOptionIndex);
            $('.alert', $shippingOptionsContainer).remove();
            $shippingOptionsContainer.append(newForm);
            shippingOptionIndex++;
            $shippingOptionsContainer.data('index', shippingOptionIndex);
            var $lastSel = $shippingOptionsContainer.find('.shipping-option-item:last .shipping-option-name-input');
            if ($lastSel.length) {
                $lastSel[0].dispatchEvent(new Event('change', { bubbles: true }));
            }
            if (typeof window.refreshShippingAddButton === 'function') {
                window.refreshShippingAddButton();
            }
            lucide.createIcons();
        });

        $(document).on('click', '.remove-shipping-option', function() {
            $(this).closest('.shipping-option-item').remove();

            if ($('.shipping-option-item', $shippingOptionsContainer).length === 0) {
                $shippingOptionsContainer.append('<div class="alert alert-info">Aucune option d\'expédition ajoutée. Cliquez sur le bouton + pour commencer.</div>');
            }
            if (typeof window.refreshShippingAddButton === 'function') {
                window.refreshShippingAddButton();
            }
        });

        function resolveImagePreviewContainer(input) {
            var dz = input.closest('.product-proposal-dropzone');
            if (dz) {
                var el = dz.querySelector('.image-upload-container');
                if (el) {
                    return el;
                }
            }
            return input.closest('.image-upload-container');
        }

        // Gestion des images
        function handleImageUpload(input, container) {
            if (!container) {
                return;
            }
            if (input.files && input.files.length > 0) {
                Array.from(input.files).forEach(file => {
                    if (file.type.startsWith('image/')) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            const preview = document.createElement('div');
                            preview.className = 'image-preview temp';
                            preview.innerHTML = `
                                <img src="${e.target.result}" alt="Image preview">
                                <button type="button" class="remove-image">
                                    <i data-lucide="x" style="width: 16px; height: 16px;"></i>
                                </button>
                            `;
                            
                            container.appendChild(preview);
                            
                            // Réinitialiser les icônes Lucide
                            if (typeof lucide !== 'undefined') {
                                lucide.createIcons();
                            }
                            
                            // Ajouter l'événement de suppression pour cette prévisualisation
                            preview.querySelector('.remove-image').addEventListener('click', function() {
                                preview.remove();
                                
                                // Créer un nouveau FileList sans ce fichier
                                const dt = new DataTransfer();
                                const files = input.files;
                                for (let i = 0; i < files.length; i++) {
                                    const currentFile = files[i];
                                    if (currentFile !== file) {
                                        dt.items.add(currentFile);
                                    }
                                }
                                input.files = dt.files;
                            });
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }
        }
        
        // Gérer l'upload d'images pour les formulaires existants et nouveaux
        $(document).on('change', '.image-upload-input', function() {
            handleImageUpload(this, resolveImagePreviewContainer(this));
        });
        
        // Gérer la suppression d'images existantes
        $(document).on('click', '.remove-image', function(e) {
            e.preventDefault();
            const $preview = $(this).closest('.image-preview');
            const $container = $preview.closest('.image-upload-container');
            const imageToRemove = $(this).data('image');
            
            if (imageToRemove) {
                // C'est une image existante, créer un champ caché pour la suppression
                let $removedImagesInput = $container.find('input[name$="[removedImages][]"]');
                if (!$removedImagesInput.length) {
                    $removedImagesInput = $('<input type="hidden" name="removedImages[]">');
                    $container.append($removedImagesInput);
                }
                $removedImagesInput.val(imageToRemove);
            }
            
            $preview.remove();
        });
    });
</script>
{% endblock %} 