<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="robots" content="noindex, nofollow">
        <title>{% block title %}Administration - Duo Import MDG{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}">
        
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Lucide Icons -->
        <script src="https://unpkg.com/lucide@latest"></script>
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        
        <!-- Admin CSS -->
        <link rel="stylesheet" href="{{ asset('css/admin/style.min.css') }}">
        
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        {# Fond assombri mobile : clic pour fermer le menu latéral #}
        <div id="adminSidebarBackdrop" class="admin-sidebar-backdrop" aria-hidden="true"></div>
        <div id="admin-sidebar" class="admin-sidebar collapsed">
            <div class="sidebar-header">
                <img src="{{ asset('images/logo.webp') }}" alt="Duo Import MDG">
                <h5 class="mt-2 mb-0">Administration</h5>
            </div>
            
            <ul class="sidebar-menu">
                <li>
                    <a href="{{ path('app_admin_dashboard') }}" class="{{ app.request.get('_route') == 'app_admin_dashboard' ? 'active' : '' }}">
                        <i data-lucide="layout-dashboard"></i> <span>Tableau de bord</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_quote_dashboard') }}" class="{{ app.request.get('_route') starts with 'app_quote' ? 'active' : '' }}">
                        <i data-lucide="file-text"></i> <span>Devis</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_admin_quote_settings') }}" class="{{ app.request.get('_route') == 'app_admin_quote_settings' ? 'active' : '' }}">
                        <i data-lucide="settings"></i> <span>Paramètres des devis</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_admin_suspicious_users') }}" class="{{ app.request.get('_route') == 'app_admin_suspicious_users' ? 'active' : '' }}">
                        <i data-lucide="user-cog"></i> <span>Utilisateurs suspects</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_admin_admin_users_index') }}" class="{{ app.request.get('_route') starts with 'app_admin_admin_users_' ? 'active' : '' }}">
                        <i data-lucide="users"></i> <span>Administrateurs</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_admin_import_products') }}" class="{{ app.request.get('_route') starts with 'app_admin_import_product' ? 'active' : '' }}">
                        <i data-lucide="package"></i> <span>Produits d'import</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_admin_import_orders') }}" class="{{ app.request.get('_route') starts with 'app_admin_import_order' ? 'active' : '' }}">
                        <i data-lucide="shopping-cart"></i> <span>Commandes d'import</span>
                    </a>
                </li>
            </ul>
            
            <ul class="bottom-menu">
                <li>
                    <a href="{{ path('app_home') }}">
                        <i data-lucide="home"></i> <span>Retour au site</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_logout') }}">
                        <i data-lucide="log-out"></i> <span>Déconnexion</span>
                    </a>
                </li>
            </ul>
        </div>
        
        <div class="admin-content expanded">
            <header class="admin-header">
                <button type="button" id="sidebarCollapse" class="btn-icon admin-header__toggle" aria-label="Ouvrir ou fermer le menu">
                    <i data-lucide="panel-left"></i>
                </button>
                <span class="separator mx-2 admin-header__sep d-none d-md-inline" aria-hidden="true">|</span>
                <nav class="admin-header__breadcrumb min-w-0" aria-label="Fil d'Ariane">
                    <div class="dropdown admin-breadcrumb-dropdown">
                        <button type="button" class="btn btn-sm btn-light border dropdown-toggle admin-breadcrumb-toggle" id="adminBreadcrumbToggle" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false" aria-haspopup="true" aria-controls="adminBreadcrumbMenu">
                            <span class="admin-breadcrumb-current text-truncate">Navigation</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end admin-breadcrumb-menu py-1 shadow-sm" id="adminBreadcrumbMenu" aria-labelledby="adminBreadcrumbToggle">
                            <li><a class="dropdown-item" href="{{ path('app_admin_dashboard') }}">Administration</a></li>
                            {% block breadcrumb %}{% endblock %}
                        </ul>
                    </div>
                </nav>
                <div class="user-dropdown admin-header__user">
                    <span class="me-2 d-none d-sm-inline admin-header__user-name">{{ app.user.firstName }} {{ app.user.lastName }}</span>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Compte utilisateur">
                            <i data-lucide="user-circle"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton">
                            <li><a class="dropdown-item" href="{{ path('app_user_profile') }}">Mon profil</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_logout') }}">Déconnexion</a></li>
                        </ul>
                    </div>
                </div>
            </header>
            
            <div class="container-fluid">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
                
                {% block body %}{% endblock %}
            </div>
        </div>
        
        <!-- Bootstrap Bundle with Popper -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        <!-- Admin Scripts -->
        <script src="{{ asset('js/admin/scripts.min.js') }}"></script>
        
        <!-- Initialize Lucide icons -->
        <script>
            lucide.createIcons();
        </script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html> 