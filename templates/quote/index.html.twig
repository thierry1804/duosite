{% extends 'base.html.twig' %}

{% block title %}Demande de devis - Duo Import MDG{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css" crossorigin="anonymous">
<style>
    .loader-container {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.8);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }
    
    .loader {
        border: 5px solid #f3f3f3;
        border-radius: 50%;
        border-top: 5px solid #0d6efd;
        width: 50px;
        height: 50px;
        animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    .loader-text {
        margin-top: 20px;
        font-size: 1.2em;
        color: #0d6efd;
    }
    
    .quote-item {
        position: relative;
        background-color: #f8f9fa;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 5px;
        border-left: 4px solid #0d6efd;
    }
    
    .remove-item {
        position: absolute;
        top: 10px;
        right: 10px;
        cursor: pointer;
        color: #dc3545;
        font-size: 1.2em;
    }
    
    .product-image {
        max-width: 100%;
        height: auto;
        max-height: 200px;
        object-fit: contain;
    }

    /* Required field indicator */
    label.required::after {
        content: " *";
        color: #dc3545;
    }

    /* Make validation errors visible */
    .invalid-feedback {
        display: block;
    }
    
    .add-item-btn {
        margin-bottom: 20px;
    }
    
    .photo-container {
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
    .photo-upload-container {
        border: 2px dashed #ddd;
        border-radius: 5px;
        padding: 15px;
        text-align: center;
        height: 100%;
        min-height: 200px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    
    .photo-upload-container label {
        cursor: pointer;
        margin-bottom: 10px;
    }
    
    .photo-upload-container input[type="file"] {
        display: none;
    }
    
    .photo-upload-icon {
        font-size: 40px;
        color: #6c757d;
        margin-bottom: 10px;
    }
    
    .product-photo-preview {
        max-width: 100%;
        max-height: 250px;
        margin-top: 10px;
        border-radius: 4px;
        display: none;
        object-fit: contain;
    }

    .shipping-method-options .form-check {
        height: 1px;
        min-height: 1px;
        margin: 0;
    }

    .quote-page-heading {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .quote-page-heading h1 { margin: 0; }
    .quote-page-tour-btn {
        border-color: var(--primary-color, #2b4eff);
        color: var(--primary-color, #2b4eff);
        font-weight: 600;
        border-radius: 8px;
    }
    .quote-page-tour-btn:hover {
        background: var(--primary-color, #2b4eff);
        border-color: var(--primary-color, #2b4eff);
        color: #fff;
    }
    .driver-popover.driver-popover-quote {
        font-family: 'Poppins', 'Poppins Fallback', sans-serif;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
        max-width: min(380px, calc(100vw - 32px));
    }
    .driver-popover.driver-popover-quote .driver-popover-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1a1a1a;
        letter-spacing: -0.02em;
    }
    .driver-popover.driver-popover-quote .driver-popover-description {
        font-size: 0.9375rem;
        color: #444444;
        line-height: 1.55;
    }
    .driver-popover.driver-popover-quote footer.driver-popover-footer,
    .driver-popover.driver-popover-quote .driver-popover-footer {
        background: #fff !important;
        color: #444444 !important;
        padding: 0.75rem 0 0 !important;
        margin-top: 0.75rem !important;
        border-top: 1px solid #e5e7eb;
        gap: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
    }
    .driver-popover.driver-popover-quote .driver-popover-progress-text {
        font-size: 0.8125rem;
        color: #6b7280;
        font-weight: 500;
    }
    .driver-popover.driver-popover-quote .driver-popover-navigation-btns { gap: 0.5rem; }
    .driver-popover.driver-popover-quote .driver-popover-next-btn {
        background: var(--primary-color, #2b4eff) !important;
        border: 1px solid var(--primary-color, #2b4eff) !important;
        color: #fff !important;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.45rem 1rem;
        border-radius: 8px;
        text-shadow: none;
    }
    .driver-popover.driver-popover-quote .driver-popover-next-btn:hover {
        background: var(--primary-dark, #1a3dff) !important;
        border-color: var(--primary-dark, #1a3dff) !important;
        color: #fff !important;
    }
    .driver-popover.driver-popover-quote .driver-popover-prev-btn {
        background: #fff !important;
        border: 1px solid #d1d5db !important;
        color: #444444 !important;
        font-weight: 500;
        font-size: 0.875rem;
        padding: 0.45rem 1rem;
        border-radius: 8px;
        text-shadow: none;
    }
    .driver-popover.driver-popover-quote .driver-popover-prev-btn:hover {
        background: #f9fafb !important;
        border-color: #9ca3af !important;
        color: #1a1a1a !important;
    }
    .driver-popover.driver-popover-quote .driver-popover-close-btn {
        color: #6b7280 !important;
        border-radius: 6px;
        opacity: 1;
    }
    .driver-popover.driver-popover-quote .driver-popover-close-btn:hover {
        color: #1a1a1a !important;
        background: #f3f4f6 !important;
    }

    /* Modale paiement devis : un peu plus large */
    .quote-payment-modal .modal-dialog {
        max-width: min(720px, calc(100vw - 2rem));
    }

    /* Bloc « Deux possibilités » — attirer l’œil sans agresser */
    .quote-payment-two-options {
        border-radius: 8px;
        padding: 0.85rem 1rem;
        margin-bottom: 1rem;
        background: #f0f7ff;
        border: 2px solid #0d6efd;
        animation: quote-payment-two-options-blink 1.4s ease-in-out infinite;
    }
    @keyframes quote-payment-two-options-blink {
        0%, 100% {
            opacity: 1;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.25);
        }
        50% {
            opacity: 0.88;
            border-color: #6ea8fe;
            box-shadow: 0 0 12px 2px rgba(13, 110, 253, 0.2);
        }
    }
    @media (prefers-reduced-motion: reduce) {
        .quote-payment-two-options {
            animation: none;
            opacity: 1;
        }
    }

</style>
{% endblock %}

{% block body %}
{% if app_quote_order_suspended %}
<div class="container py-5">
    {% for label, messages in app.flashes %}
        {% if label == 'success' or label == 'error' or label == 'warning' %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endif %}
    {% endfor %}
    {% include '_service_suspended_notice.html.twig' %}
</div>
{% else %}
<div class="container py-5">
    <div class="quote-page-heading">
        <h1>Demande de devis</h1>
        <button type="button" class="btn btn-outline-primary btn-sm quote-page-tour-btn" id="quotePageTourBtn">Guide du formulaire</button>
    </div>
    
    <p class="mb-4">
        Veuillez remplir ce formulaire avec les détails de votre projet.
    </p>

    {% for label, messages in app.flashes %}
        {% if label == 'success' or label == 'error' or label == 'warning' %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endif %}
    {% endfor %}
    
    {% if form.vars.submitted and not form.vars.valid %}
    <div class="alert alert-warning mb-4">
        <p class="mb-2"><strong>Champs obligatoires pour chaque produit :</strong></p>
        <ul class="mb-0">
            <li>Le type de produit</li>
            <li>La description du produit</li>
            <li>La quantité</li>
        </ul>
    </div>
    {% endif %}
    
    <!-- Loader -->
    <div id="loader" class="loader-container" style="display: none;">
        <div class="loader"></div>
        <p class="loader-text">Envoi de votre demande en cours...</p>
    </div>
    
    {{ form_start(form, {'attr': {
        'class': 'needs-validation',
        'id': 'quoteForm',
        'novalidate': 'novalidate',
        'data-free-items-limit': freeItemsLimit|default(2),
        'data-item-price': itemPrice|default(0)
    }}) }}
        {{ form_errors(form) }}

        <div id="tour-quote-coordinates">
        <h2 class="mt-4 mb-3">1. Vos coordonnées</h2>
        
        <div class="row mb-3">
            <div class="col-md-6">
                {{ form_row(form.firstName, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.lastName, {'attr': {'class': 'form-control'}}) }}
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                {{ form_row(form.email, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.phone, {'attr': {'class': 'form-control'}}) }}
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                {{ form_row(form.company, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="col-md-6">
                {{ form_label(form.referralSource) }}
                {{ form_widget(form.referralSource, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.referralSource) }}
            </div>
        </div>
        </div>
        
        <div id="tour-quote-products-block">
        <h2 class="mt-4 mb-3">2. Détails du ou des produits</h2>
        
        <div class="quote-items-wrapper" 
             data-prototype="{{ form_widget(form.items.vars.prototype)|e('html_attr') }}"
             data-index="{{ form.items|length > 0 ? form.items|last.vars.name + 1 : 0 }}">
            
            {% for itemForm in form.items %}
                <div class="quote-item">
                    <span class="remove-item"><i class="fas fa-times-circle"></i></span>
                    <div class="row">
                        <!-- Photo à gauche (1/3) -->
                        <div class="col-md-4 mb-3">
                            <div class="photo-container">
                                <div class="photo-upload-container">
                                    <label for="{{ itemForm.photoFile.vars.id }}" class="upload-label">
                                        <div class="photo-upload-icon">
                                            <i class="fas fa-camera"></i>
                                        </div>
                                        <span>Cliquez pour ajouter une photo</span>
                                    </label>
                                    {{ form_widget(itemForm.photoFile, {'attr': {'class': 'form-control-file d-none'}}) }}
                                    <img src="#" class="product-photo-preview" alt="Aperçu de la photo">
                                </div>
                                {{ form_errors(itemForm.photoFile) }}
                            </div>
                        </div>
                        
                        <!-- Informations à droite (2/3) -->
                        <div class="col-md-8">
                            <div class="row">
                                <!-- Type, quantité et budget sur la même ligne -->
                                <div class="col-md-4 mb-3">
                                    {{ form_row(itemForm.productType, {'attr': {'class': 'form-select product-type-select'}}) }}
                                </div>
                                <div class="col-md-4 mb-3">
                                    {{ form_row(itemForm.quantity, {'attr': {'class': 'form-control', 'min': 1}}) }}
                                </div>
                                <div class="col-md-4 mb-3">
                                    {{ form_row(itemForm.budget, {'attr': {'class': 'form-control', 'min': 0}}) }}
                                </div>
                                
                                <!-- Description en dessous -->
                                <div class="col-12 mb-3">
                                    {{ form_row(itemForm.description) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        
        <button
            type="button"
            class="btn btn-outline-primary add-item-btn"
            id="quote-add-item-btn"
            data-free-items-limit="{{ freeItemsLimit|default(2) }}"
        >
            <i class="fas fa-plus-circle me-2"></i> Ajouter un produit
        </button>
        <p class="small text-muted mb-4">
            Les {{ freeItemsLimit|default(2) }} premiers articles sont gratuits. À partir du {{ (freeItemsLimit|default(2)) + 1 }}e article, chaque article supplémentaire est facturé {{ itemPrice|default(0)|number_format(0, ',', ' ') }} Ar.
        </p>
        </div>
        
        <div id="tour-quote-shipping">
        <h2 class="mt-4">3. Choix de l'envoi</h2>
        <div class="row mb-4">
            <!-- Services masqués (pré-sélectionnés automatiquement) -->
            <div style="display: none;">
                {{ form_row(form.services) }}
            </div>
            <div class="col-12">
                <div class="alert alert-light border d-flex align-items-start gap-3">
                    <i class="fas fa-check-circle text-primary mt-1"></i>
                    <p class="mb-0">
                        Nous gérons le sourcing, la négociation fournisseurs et toute la logistique
                        (transport, dédouanement, livraison) pour une réception simple et sans stress.<br/>
                        Vous devez juste définir le mode d'envoi. <strong>Cliquez donc sur le ou les modes d'envoi qui vous conviennent et nous nous occuperons du reste.</strong>
                    </p>
                </div>
            </div>
            <!-- Choix de l'envoi (pleine largeur) -->
            <div class="col-12">
                <div class="mb-3 shipping-method-container">
                    {{ form_label(form.shippingMethod, null, {'label_attr': {'class': 'd-none'}}) }}
                    <div class="shipping-method-options row px-2">
                        {% for choice in form.shippingMethod %}
                            <div class="col-4 col-sm-4 col-md-4 col-lg-4 mb-2">
                                <label class="radio-card h-100">
                                    {{ form_widget(choice, {'attr': {'class': 'radio-card-input'}, 'label': false, 'label_attr': {'class': 'd-none'}}) }}
                                    <div class="radio-card-content">
                                        <div class="shipping-icon">
                                            {% if choice.vars.value == 'maritime' %}
                                                <i class="fas fa-ship"></i>
                                            {% elseif choice.vars.value == 'aerien_express' %}
                                                <i class="fas fa-plane-departure"></i>
                                            {% elseif choice.vars.value == 'aerien_normal' %}
                                                <i class="fas fa-plane"></i>
                                            {% endif %}
                                        </div>
                                        <span class="radio-card-label">{{ choice.vars.label }}</span>
                                    </div>
                                </label>
                            </div>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.shippingMethod) }}
                    <p class="small text-muted mt-2 fst-italic">
                        <strong>Les envois aériens</strong> ont un départ hebdomadaire. Les délais de <strong>3 à 5 jours</strong> et <strong>10 à 30 jours</strong> <u>commencent uniquement à partir du départ de l’avion</u>, après réception des marchandises auprès des fournisseurs.
                    </p>
                </div>
            </div>
        </div>
        </div>
        
        <div id="tour-quote-additional">
        <h2 class="pt-5 mt-5 mb-4">4. Informations complémentaires</h2>
        <div class="mb-4">
            {{ form_widget(form.additionalInfo, {'attr': {'class': 'form-control', 'rows': 3}}) }}
            {{ form_errors(form.additionalInfo) }}
        </div>
        </div>

        <div class="mb-3" style="padding-left: 0 !important;" id="tour-quote-privacy">
            <label for="{{ form.privacyPolicy.vars.id }}" class="form-check-label" style="display: flex; align-items: flex-start; gap: 8px; line-height: 1.5;">
                {{ form_widget(form.privacyPolicy, {'attr': {'class': 'form-check-input', 'style': 'margin: 0; margin-top: 2px; margin-left: -24px;'}}) }}
                J'accepte la <a href="{{ path('app_privacy_policy') }}" target="_blank">politique de confidentialité</a>
            </label>
            {{ form_errors(form.privacyPolicy) }}
        </div>

        <p class="mb-4">
            Notre équipe vous contactera dans les 24 à 72 heures avec un devis personnalisé.
        </p>

        <div class="" id="tour-quote-submit">
            <button type="submit" class="btn btn-primary" id="submitButton">Soumettre ma demande de devis</button>
        </div>
    {{ form_end(form) }}
</div>

<div class="modal fade quote-payment-modal" id="quotePaymentModal" tabindex="-1" aria-labelledby="quotePaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="quotePaymentModalLabel">Paiement — au-delà de {{ freeItemsLimit|default(2) }} articles</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Vous avez atteint la limite des {{ freeItemsLimit|default(2) }} articles gratuits.</p>
                <div class="quote-payment-two-options small mb-3" role="status" aria-live="polite">
                    <p class="mb-0">
                        <strong>Deux possibilités :</strong> fermez cette fenêtre avec « Annuler », supprimez les lignes produits en trop (croix rouge) pour ne garder que {{ freeItemsLimit|default(2) }} articles au maximum, puis renvoyez votre demande sans frais.
                        Sinon, effectuez le paiement indiqué ci-dessous pour envoyer votre demande avec plus de {{ freeItemsLimit|default(2) }} articles.
                    </p>
                </div>
                <p class="mb-2">À partir du {{ (freeItemsLimit|default(2)) + 1 }}e article, chaque article supplémentaire est facturé <strong>{{ itemPrice|default(0)|number_format(0, ',', ' ') }} Ar</strong>.</p>
                <div class="alert alert-light border mb-3">
                    <div class="d-flex justify-content-between">
                        <span>Articles payants</span>
                        <strong id="quotePaymentPaidItems">0</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Prix unitaire</span>
                        <strong id="quotePaymentItemPrice">{{ itemPrice|default(0)|number_format(0, ',', ' ') }} Ar</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Montant total à payer</span>
                        <strong id="quotePaymentTotal">0 Ar</strong>
                    </div>
                </div>
                <p class="mb-2">
                    Veuillez effectuer le paiement au numéro suivant :
                    <strong id="quotePaymentPhone">{{ primaryContactPhone }}</strong>
                    <span class="text-muted"> (il est préférable de confirmer le paiement par appel, s'il vous plaît)</span>
                </p>
                <p class="mb-2 small text-muted">
                    <strong>Important :</strong> le paiement ne signifie pas un traitement immédiat de votre demande.
                    Le devis sera traité dans un délai de <strong>24 h à 72 h après confirmation du paiement</strong> par notre équipe.
                </p>
                <p class="mb-3">Ensuite, indiquez la référence de votre paiement ci-dessous pour envoyer votre demande.</p>
                <label for="quotePaymentReferenceInput" class="form-label">Référence de paiement</label>
                <input type="text" id="quotePaymentReferenceInput" class="form-control" placeholder="Ex: TXN-123456" />
                <div id="quotePaymentReferenceError" class="text-danger small mt-2 d-none">
                    Veuillez renseigner la référence de paiement.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="quotePaymentValidateBtn">Valider et envoyer</button>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if not app_quote_order_suspended %}
<script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js" crossorigin="anonymous"></script>
<script src="{{ asset('js/quote.js') }}" defer></script>
<script>
(function() {
    function getDriverFactory() {
        if (typeof window.driver !== "undefined" && window.driver && window.driver.js && window.driver.js.driver) {
            return window.driver.js.driver;
        }
        return null;
    }
    function buildQuoteTourSteps() {
        return [
            {
                popover: {
                    title: "Demande de devis",
                    description: "Ce guide présente les sections du formulaire : vos coordonnées, les produits, le mode d'envoi, les informations complémentaires et l'envoi.",
                    side: "over",
                    align: "center"
                }
            },
            {
                element: "#tour-quote-coordinates",
                popover: {
                    title: "Vos coordonnées",
                    description: "Indiquez votre identité, vos moyens de contact et, si vous le souhaitez, comment vous nous avez connus.",
                    side: "bottom"
                }
            },
            {
                element: "#tour-quote-products-block",
                popover: {
                    title: "Produits",
                    description: "Pour chaque ligne : photo éventuelle, type, quantité, budget et description. Ajoutez des lignes si vous avez plusieurs produits.",
                    side: "bottom"
                }
            },
            {
                element: "#quote-add-item-btn",
                popover: {
                    title: "Plusieurs produits",
                    description: "Utilisez ce bouton pour ajouter un bloc produit supplémentaire à votre demande.",
                    side: "bottom"
                }
            },
            {
                element: "#tour-quote-shipping",
                popover: {
                    title: "Choix de l'envoi",
                    description: "Sélectionnez un ou plusieurs modes d'expédition (maritime ou aérien). Les délais indiqués sont donnés à titre indicatif.",
                    side: "top"
                }
            },
            {
                element: "#tour-quote-additional",
                popover: {
                    title: "Informations complémentaires",
                    description: "Champ libre pour préciser des contraintes, délais ou tout élément utile à l'étude de votre dossier.",
                    side: "top"
                }
            },
            {
                element: "#tour-quote-privacy",
                popover: {
                    title: "Confidentialité",
                    description: "Vous devez accepter la politique de confidentialité pour envoyer votre demande.",
                    side: "top"
                }
            },
            {
                element: "#tour-quote-submit",
                popover: {
                    title: "Envoyer",
                    description: "Après validation, notre équipe vous recontacte sous 24 à 72 h avec un devis personnalisé.",
                    side: "top"
                }
            }
        ];
    }
    var quoteTourLock = false;
    function startQuoteTour() {
        if (quoteTourLock) {
            return;
        }
        var driverFn = getDriverFactory();
        if (!driverFn) {
            return;
        }
        quoteTourLock = true;
        var tour = driverFn({
            showProgress: true,
            smoothScroll: true,
            allowClose: true,
            overlayOpacity: 0.5,
            overlayColor: "#1a1a1a",
            stageRadius: 8,
            stagePadding: 8,
            popoverClass: "driver-popover-quote",
            nextBtnText: "Suivant",
            prevBtnText: "Précédent",
            doneBtnText: "Terminer",
            progressText: "{{ '{{' }}current{{ '}}' }} / {{ '{{' }}total{{ '}}' }}",
            steps: buildQuoteTourSteps(),
            onDestroyed: function() {
                quoteTourLock = false;
                try {
                    localStorage.setItem("duoimport_quote_tour_seen", "1");
                } catch (err) {}
            }
        });
        tour.drive(0);
    }
    function quoteTourReady() {
        var btn = document.getElementById("quotePageTourBtn");
        if (btn) {
            btn.addEventListener("click", function() {
                startQuoteTour();
            });
        }
        try {
            if (!localStorage.getItem("duoimport_quote_tour_seen")) {
                setTimeout(function() {
                    if (!localStorage.getItem("duoimport_quote_tour_seen")) {
                        startQuoteTour();
                    }
                }, 500);
            }
        } catch (err) {}
    }
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", quoteTourReady);
    } else {
        quoteTourReady();
    }
})();
</script>
{% endif %}
{% endblock %} 